EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# AI provider routing only (no secret keys in app env):
# "gemini", "anthropic", or "openai" (openai also works with OpenRouter)
EXPO_PUBLIC_AI_PROVIDER=gemini
EXPO_PUBLIC_AI_MODEL=gemini-2.5-flash-lite
# Optional for OpenAI-compatible hosts like OpenRouter
# EXPO_PUBLIC_AI_API_BASE=https://api.openai.com/v1
